{
  "datasets": ["svamp"],
  "generators": ["Complete", "Random", "Layer", "Chain", "Star"],
  "llm_name": "qwen3-8b",
  "base_urls": "http://127.0.0.1:8003/v1,http://127.0.0.1:8004/v1",
  "disable_thinking": true,
  "max_tokens": 4096,
  "temperature": 0.2,
  "top_p": 0.95,
  "batch_size": 4,
  "num_rounds": 2,
  "calibration_examples": 8,
  "estimator": "mask_sampling",
  "mask_samples": 12,
  "edge_keep_prob": 0.75,
  "node_keep_prob": 0.8,
  "intervention_types": "both",
  "pruning_rate": 0.25,
  "node_pruning_rate": 0.2,
  "min_nodes": 2,
  "parallel_interventions": 1,
  "mmlu_limit": 153,
  "trace_code_timeout": 2,
  "final_code_timeout": 100,
  "explainer_epochs": 200,
  "explainer_hidden_dim": 128,
  "explainer_lr": 0.001,
  "explainer_weight_decay": 0.0001,
  "explainer_dropout": 0.15,
  "sparsity_weight": 0.02,
  "entropy_weight": 0.001,
  "mask_scope": "task"
}

